# GhostDrive Configuration
# Edit these to customize behavior.

# Port for Ollama server (change if 11435 conflicts with something)
OLLAMA_PORT=11435

# Default model to load when no model is specified
# Must match a model name from: bash models.sh list
DEFAULT_MODEL=gemma3:4b

# Flash attention (1=on, 0=off). Improves speed on supported hardware.
OLLAMA_FLASH_ATTENTION=1

# Max concurrent requests
OLLAMA_NUM_PARALLEL=2

# Max models loaded in memory at once (keep at 1 for 8-16GB RAM machines)
OLLAMA_MAX_LOADED_MODELS=1
